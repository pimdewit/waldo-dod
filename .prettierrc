{
  "singleQuote": true,
  "trailingComma": "none",
  "printWidth": 100,
  "plugins": ["prettier-plugin-svelte", "prettier-plugin-tailwindcss"],
  "overrides": [
    {
      "files": "*.svelte",
      "options": { "parser": "svelte" }
    },
    {
      "files": "apps/web/**",
      "options": { "tailwindStylesheet": "./apps/web/src/lib/styles/main.css" }
    }
  ]
}
